#ifndef %{LIBNAME}_CONFIG_HPP
#define %{LIBNAME}_CONFIG_HPP

#include "okbase/core_defines.hpp"

#define %{LIBNAME}_VERSION_MAJOR ${VERSION_MAJOR}
#define %{LIBNAME}_VERSION_MINOR ${VERSION_MINOR}
#define %{LIBNAME}_VERSION_PATCH ${VERSION_ALTER}

/**
 * Encoded version of %{libname} as 'MajorMinorPatch'.
 * @see OKL_ENCODE_VERSION
 */
#define %{LIBNAME}_VERSION OKL_ENCODE_VERSION(%{LIBNAME}_VERSION_MAJOR, %{LIBNAME}_VERSION_MINOR, %{LIBNAME}_VERSION_PATCH)

${define_export %{LIBNAME}}

#endif
