#ifndef OKTEST_CONFIG_HPP
#define OKTEST_CONFIG_HPP

#include "okutils/core_defines.hpp"

#if !defined(OKTEST_MAX_NESTED_NODES)
	#define OKTEST_MAX_NESTED_NODES @OKTEST_MAX_NESTED@
#endif

#if !defined(OKTEST_WITH_EXCEPTIONS)
	#if !defined(__cpp_exceptions) || __cpp_exceptions == 0
		#define OKTEST_WITH_EXCEPTIONS 0
	#else
 	#define OKTEST_WITH_EXCEPTIONS @OKTEST_WITH_EXCEPTIONS_VALUE@
	#endif
#endif

#if !defined(OKTEST_LINK_MAIN)
	#define OKTEST_LINK_MAIN @OKTEST_LINK_MAIN_VALUE@
#endif

#define OKTEST_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define OKTEST_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define OKTEST_VERSION_PATCH @PROJECT_VERSION_PATCH@

/**
 * Encoded version of oktest as 'MajorMinorPatch'.
 * @see OKL_ENCODE_VERSION
 */
#define OKTEST_VERSION OKL_ENCODE_VERSION(OKTEST_VERSION_MAJOR, OKTEST_VERSION_MINOR, OKTEST_VERSION_PATCH)

#define OKTEST_EXPORT

#endif
